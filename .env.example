# PromptClash backend config — copy to your shell before running uvicorn.
# NOT auto-loaded (no python-dotenv). Export the vars manually:
#   PowerShell:  $env:AZURE_OPENAI_API_KEY = "..."
#   bash/zsh:    export AZURE_OPENAI_API_KEY=...
#   or load all: set -a; source .env; set +a
#
# ALL optional. With no Azure key + endpoint, the judge uses a deterministic
# heuristic scorer — the game still runs end to end.

# --- Azure OpenAI judge ---
# Resource key + endpoint. Leave blank to force the heuristic fallback.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://my-resource.openai.azure.com
# Your chat model deployment name (default: gpt-4o-mini)
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# Azure API version (default: 2024-10-21)
AZURE_OPENAI_API_VERSION=2024-10-21

# --- Demo / rehearsal mode ---
# true => pre-create room "DEMO" with 5 fake players who auto-submit
# varied-quality prompts 10s after each round starts. Rehearse solo /
# wifi-death fallback. Anything else / unset => off.
DEMO_MODE=false
